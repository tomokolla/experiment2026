      <CodeComponent name="name_code" plugin="None">
        <Param val="" valType="extendedCode" updates="constant" name="Before Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Before JS Experiment"/>
        <Param val="name_text = &quot;&quot;" valType="extendedCode" updates="constant" name="Begin Experiment"/>
        <Param val="name_text = &quot;&quot;;" valType="extendedCode" updates="constant" name="Begin JS Experiment"/>
        <Param val="name_text = &quot;&quot;;" valType="extendedCode" updates="constant" name="Begin JS Routine"/>
        <Param val="name_text = &quot;&quot;" valType="extendedCode" updates="constant" name="Begin Routine"/>
        <Param val="Both" valType="str" updates="None" name="Code Type"/>
        <Param val="keys = event.getKeys()&amp;#10;for key in keys:&amp;#10;    if key == 'return' and len(name_text) &gt; 0:&amp;#10;        continueRoutine = False&amp;#10;    elif key == 'backspace':&amp;#10;        name_text = name_text[:-1]&amp;#10;    elif len(key) == 1:&amp;#10;        name_text += key&amp;#10;&amp;#10;if int(t * 2) % 2 == 0:&amp;#10;    name_cursor.text = name_text + '|'&amp;#10;else:&amp;#10;    name_cursor.text = name_text + ' '" valType="extendedCode" updates="constant" name="Each Frame"/>
        <Param val="let keys = psychoJS.eventManager.getKeys();&amp;#10;for (let i = 0; i &lt; keys.length; i++) {&amp;#10;    let key = keys[i];&amp;#10;    if (key === 'return' &amp;&amp; name_text.length &gt; 0) {&amp;#10;        continueRoutine = false;&amp;#10;    } else if (key === 'backspace') {&amp;#10;        name_text = name_text.slice(0, -1);&amp;#10;    } else if (key.length === 1) {&amp;#10;        name_text += key;&amp;#10;    }&amp;#10;}&amp;#10;&amp;#10;if (Math.floor(t * 2) % 2 === 0) {&amp;#10;    name_cursor.setText(name_text + '|');&amp;#10;} else {&amp;#10;    name_cursor.setText(name_text + ' ');&amp;#10;}" valType="extendedCode" updates="constant" name="Each JS Frame"/>
        <Param val="" valType="extendedCode" updates="constant" name="End Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="End JS Experiment"/>
        <Param val="psychoJS.experiment.addData('participant_name', name_box.text);" valType="extendedCode" updates="constant" name="End JS Routine"/>
        <Param val="thisExp.addData('participant_name', name_box.text)" valType="extendedCode" updates="constant" name="End Routine"/>
        <Param val="True" valType="bool" updates="None" name="disabled"/>
        <Param val="name_code" valType="code" updates="None" name="name"/>
      </CodeComponent>
