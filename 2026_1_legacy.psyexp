      <CodeComponent name="mail_code" plugin="None">
        <Param val="" valType="extendedCode" updates="constant" name="Before Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Before JS Experiment"/>
        <Param val="mail_text = &quot;&quot;&amp;#10;event.clearEvents()" valType="extendedCode" updates="constant" name="Begin Experiment"/>
        <Param val="mail_text = &quot;&quot;;&amp;#10;psychoJS.eventManager.clearEvents();" valType="extendedCode" updates="constant" name="Begin JS Experiment"/>
        <Param val="mail_text = &quot;&quot;;" valType="extendedCode" updates="constant" name="Begin JS Routine"/>
        <Param val="mail_text = &quot;&quot;" valType="extendedCode" updates="constant" name="Begin Routine"/>
        <Param val="Both" valType="str" updates="None" name="Code Type"/>
        <Param val="keys = event.getKeys()&amp;#10;for key in keys:&amp;#10;    if key == 'return' and len(mail_text) &gt; 0:&amp;#10;        continueRoutine = False&amp;#10;    elif key == 'backspace':&amp;#10;        mail_text = mail_text[:-1]&amp;#10;    elif key == 'at':&amp;#10;        mail_text += '@'&amp;#10;    elif key == 'period':&amp;#10;        mail_text += '.'&amp;#10;    elif key == 'minus':&amp;#10;        mail_text += '-'&amp;#10;    elif key == 'underscore':&amp;#10;        mail_text += '_'&amp;#10;    elif len(key) == 1 and key.isalnum():&amp;#10;        mail_text += key&amp;#10;&amp;#10;if int(t * 2) % 2 == 0:&amp;#10;    mail_cursor.text = mail_text + '|'&amp;#10;else:&amp;#10;    mail_cursor.text = mail_text + ' '" valType="extendedCode" updates="constant" name="Each Frame"/>
        <Param val="let keys = psychoJS.eventManager.getKeys();&amp;#10;for (let i = 0; i &lt; keys.length; i++) {&amp;#10;  let key = keys[i];&amp;#10;  if (key === 'return' || key === 'enter' || key === 'Enter') {&amp;#10;    if (mail_text.length &gt; 0) continueRoutine = false;&amp;#10;  } else if (key === 'backspace' || key === 'Backspace') {&amp;#10;    mail_text = mail_text.slice(0, -1);&amp;#10;  } else if (key === 'BracketLeft') {&amp;#10;    mail_text += '[a]';&amp;#10;  } else if (key === '.' || key === 'period') {&amp;#10;    mail_text += '.';&amp;#10;  } else if (key === '-' || key === 'minus') {&amp;#10;    mail_text += '-';&amp;#10;  } else if (key === '_' || key === 'IntlRo') {&amp;#10;    mail_text += '_';&amp;#10;  } else if (typeof key === 'string' &amp;&amp; key.length === 1) {&amp;#10;    mail_text += key;&amp;#10;  }&amp;#10;}&amp;#10;if (Math.floor(t * 2) % 2 === 0) {&amp;#10;  mail_cursor.setText(mail_text + '|');&amp;#10;} else {&amp;#10;  mail_cursor.setText(mail_text + ' ');&amp;#10;}" valType="extendedCode" updates="constant" name="Each JS Frame"/>
        <Param val="" valType="extendedCode" updates="constant" name="End Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="End JS Experiment"/>
        <Param val="psychoJS.experiment.addData('participant_email', mail_box.text);" valType="extendedCode" updates="constant" name="End JS Routine"/>
        <Param val="thisExp.addData('participant_email', mail_box.text)" valType="extendedCode" updates="constant" name="End Routine"/>
        <Param val="True" valType="bool" updates="None" name="disabled"/>
        <Param val="mail_code" valType="code" updates="None" name="name"/>
