        <Param val="inst_sex" valType="code" updates="None" name="name"/>
        <Param val="True" valType="bool" updates="None" name="saveStartStop"/>
        <Param val="" valType="code" updates="constant" name="skipIf"/>
        <Param val="duration (s)" valType="str" updates="None" name="stopType"/>
        <Param val="" valType="code" updates="constant" name="stopVal"/>
        <Param val="False" valType="bool" updates="None" name="useWindowParams"/>
      </RoutineSettingsComponent>
      <CodeComponent name="sex_code" plugin="None">
        <Param val="" valType="extendedCode" updates="constant" name="Before Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Before JS Experiment"/>
        <Param val="sex_text = &quot;&quot;" valType="extendedCode" updates="constant" name="Begin Experiment"/>
        <Param val="sex_text = &quot;&quot;;" valType="extendedCode" updates="constant" name="Begin JS Experiment"/>
        <Param val="sex_text = &quot;&quot;;&amp;#10;psychoJS.eventManager.clearEvents();" valType="extendedCode" updates="constant" name="Begin JS Routine"/>
        <Param val="sex_text = &quot;&quot;&amp;#10;event.clearEvents()" valType="extendedCode" updates="constant" name="Begin Routine"/>
        <Param val="Both" valType="str" updates="None" name="Code Type"/>
        <Param val="keys = event.getKeys()&amp;#10;for key in keys:&amp;#10;    if key == 'return' and len(sex_text) &gt; 0 and t &gt; 0.5:&amp;#10;    continueRoutine = False&amp;#10;    elif key == 'backspace':&amp;#10;        sex_text = sex_text[:-1]&amp;#10;    elif key in ['m', 'f', 'y']:&amp;#10;        sex_text = key&amp;#10;&amp;#10;if int(t * 2) % 2 == 0:&amp;#10;    sex_cursor.text = sex_text + '|'&amp;#10;else:&amp;#10;    sex_cursor.text = sex_text + ' '" valType="extendedCode" updates="constant" name="Each Frame"/>
        <Param val="let keys = psychoJS.eventManager.getKeys();&amp;#10;for (let i = 0; i &lt; keys.length; i++) {&amp;#10;    let key = keys[i];&amp;#10;    if (key === 'return' &amp;&amp; sex_text.length &gt; 0 &amp;&amp; t &gt; 0.5) {&amp;#10;        continueRoutine = false;&amp;#10;    } else if (key === 'backspace') {&amp;#10;        sex_text = sex_text.slice(0, -1);&amp;#10;    } else if (['m', 'f', 'y'].includes(key)) {&amp;#10;        sex_text = key;&amp;#10;    }&amp;#10;}&amp;#10;&amp;#10;if (Math.floor(t * 2) % 2 === 0) {&amp;#10;    sex_cursor.setText(sex_text + '|');&amp;#10;} else {&amp;#10;    sex_cursor.setText(sex_text + ' ');&amp;#10;}" valType="extendedCode" updates="constant" name="Each JS Frame"/>
        <Param val="" valType="extendedCode" updates="constant" name="End Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="End JS Experiment"/>
        <Param val="if (sex_text === 'm') {&amp;#10;    psychoJS.experiment.addData('participant_sex', '男性');&amp;#10;} else if (sex_text === 'f') {&amp;#10;    psychoJS.experiment.addData('participant_sex', '女性');&amp;#10;} else if (sex_text === 'y') {&amp;#10;    psychoJS.experiment.addData('participant_sex', '回答しない');&amp;#10;}" valType="extendedCode" updates="constant" name="End JS Routine"/>
        <Param val="if sex_text == 'm':&amp;#10;    thisExp.addData('participant_sex', '男性')&amp;#10;elif sex_text == 'f':&amp;#10;    thisExp.addData('participant_sex', '女性')&amp;#10;elif sex_text == 'y':&amp;#10;    thisExp.addData('participant_sex', '回答しない')" valType="extendedCode" updates="constant" name="End Routine"/>
        <Param val="False" valType="bool" updates="None" name="disabled"/>
        <Param val="sex_code" valType="code" updates="None" name="name"/>
      </CodeComponent>
